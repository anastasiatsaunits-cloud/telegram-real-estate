generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FunnelStage {
  NEW
  BOT_STARTED
  MINIAPP_OPENED
  QUIZ_STARTED
  QUIZ_COMPLETED
  RECOMMENDATIONS_VIEWED
  PROPERTY_VIEWED
  LEAD_CAPTURED
  CRM_SYNCED
}

enum LeadStatus {
  NEW
  SENT_TO_CRM
  IN_PROGRESS
  WON
  LOST
}

enum ApplicationType {
  PROPERTY_REQUEST
  CONSULTATION
  CURATED_SELECTION
}

model User {
  id               String            @id @default(cuid())
  fullName         String?
  phone            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  telegramProfiles TelegramProfile[]
  sessions         Session[]
  quizAnswers      QuizAnswer[]
  leads            Lead[]
  events           Event[]
}

model TelegramProfile {
  id           String    @id @default(cuid())
  userId       String
  telegramId   String    @unique
  username     String?
  firstName    String?
  lastName     String?
  languageCode String?
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions     Session[]

  @@index([userId])
}

model Session {
  id                String           @id @default(cuid())
  userId            String
  telegramProfileId String?
  source            String?
  utmSource         String?
  utmCampaign       String?
  funnelStage       FunnelStage      @default(NEW)
  startedAt         DateTime         @default(now())
  lastSeenAt        DateTime         @default(now())
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  telegramProfile   TelegramProfile? @relation(fields: [telegramProfileId], references: [id], onDelete: SetNull)
  quizAnswers       QuizAnswer[]
  leads             Lead[]
  events            Event[]

  @@index([userId])
  @@index([telegramProfileId])
  @@index([funnelStage])
}

model QuizAnswer {
  id          String   @id @default(cuid())
  sessionId   String
  userId      String
  questionKey String
  answerValue String
  createdAt   DateTime @default(now())
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([userId])
  @@index([questionKey])
}

model Region {
  id         String     @id @default(cuid())
  name       String
  slug       String     @unique
  isActive   Boolean    @default(true)
  sortOrder  Int        @default(0)
  properties Property[]
}

model Property {
  id                  String           @id @default(cuid())
  regionId            String
  title               String
  slug                String           @unique
  city                String?
  address             String?
  priceFrom           Decimal?         @db.Decimal(14, 2)
  priceTo             Decimal?         @db.Decimal(14, 2)
  currency            String?          @default("RUB")
  areaFrom            Decimal?         @db.Decimal(10, 2)
  areaTo              Decimal?         @db.Decimal(10, 2)
  propertyType        String?
  status              String?
  description         String?
  purchaseOptionsJson Json?
  isActive            Boolean          @default(true)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  region              Region           @relation(fields: [regionId], references: [id], onDelete: Restrict)
  media               PropertyMedia[]
  metrics             PropertyMetric?
  applications        Application[]

  @@index([regionId])
  @@index([isActive])
  @@index([priceFrom])
}

model PropertyMedia {
  id        String   @id @default(cuid())
  propertyId String
  mediaType String
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  property  Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model PropertyMetric {
  id             String    @id @default(cuid())
  propertyId     String    @unique
  rentalYield    Decimal?  @db.Decimal(5, 2)
  shortTermYield Decimal?  @db.Decimal(5, 2)
  annualGrowth   Decimal?  @db.Decimal(5, 2)
  roi5y          Decimal?  @db.Decimal(7, 2)
  roi10y         Decimal?  @db.Decimal(7, 2)
  alternativeTotal Decimal? @db.Decimal(14, 2)
  payloadJson    Json?
  updatedAt      DateTime  @updatedAt
  property       Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model Lead {
  id             String     @id @default(cuid())
  userId         String
  sessionId      String
  phone          String
  regionInterest String?
  budgetRange    String?
  purchaseTerm   String?
  source         String?
  crmId          String?
  status         LeadStatus @default(NEW)
  createdAt      DateTime   @default(now())
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  session        Session    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  applications   Application[]

  @@index([userId])
  @@index([sessionId])
  @@index([crmId])
  @@index([status])
}

model Application {
  id              String          @id @default(cuid())
  leadId          String
  propertyId      String
  applicationType ApplicationType
  comment         String?
  createdAt       DateTime        @default(now())
  lead            Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  property        Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([propertyId])
}

model Event {
  id         String   @id @default(cuid())
  userId      String
  sessionId   String
  eventName   String
  payloadJson Json?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
  @@index([eventName])
}
